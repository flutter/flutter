declare_args() {
  gen_snapshot_suffix = ""
  if (host_os == "mac") {
    # Determine suffixed output gen_snapshot name.
    gen_snapshot_suffix = "_${target_cpu}"
    if (target_cpu == "arm") {
      gen_snapshot_suffix = "_armv7"
    }
  }
}
