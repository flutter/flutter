#!/bin/bash

# Generated file. Do not edit.

# exit on error, or usage of unset var
set -euo pipefail

if [[ $ACTION == "clean" ]]; then
  exit 0
fi

# Needed because if it is set, cd may print the path it changed to.
unset CDPATH

function follow_links() (
  cd -P "$(dirname -- "$1")"
  file="$PWD/$(basename -- "$1")"
  while [[ -h "$file" ]]; do
    cd -P "$(dirname -- "$file")"
    file="$(readlink -- "$file")"
    cd -P "$(dirname -- "$file")"
    file="$PWD/$(basename -- "$file")"
  done
  echo "$file"
)

# Find path to FlutterNativeIntegration
PROG_NAME="$(follow_links "${BASH_SOURCE[0]}")"
BIN_DIR="$(cd "${PROG_NAME%/*}" ; pwd -P)"
FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH="$BIN_DIR/../FlutterNativeIntegration"

# Use prebuilt flutter-prebuild-tool if possible, otherwise re-build it for next time
PREBUILT_FLUTTER_TOOL="$FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH/.build/release/flutter-prebuild-tool"
if [[ -z "${REBUILD_FLUTTER_TOOL+set}" ]] || [[ "$REBUILD_FLUTTER_TOOL" != "YES" ]]; then
  PREBUILT_FLUTTER_TOOL_SCAN=$(gktool scan "$PREBUILT_FLUTTER_TOOL") || REBUILD_FLUTTER_TOOL="YES"
  if [[ "$PREBUILT_FLUTTER_TOOL_SCAN" != *"Scan completed and software is allowed by system policy."* ]]; then
    echo "Gatekeeper check failed: $PREBUILT_FLUTTER_TOOL_SCAN"
    REBUILD_FLUTTER_TOOL="YES"
  else
    REBUILD_FLUTTER_TOOL="NO"
  fi
fi
if [[ "$REBUILD_FLUTTER_TOOL" == "YES" ]]; then
  cd "$FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH"
  env -i PATH=$PATH swift build --product flutter-prebuild-tool -c release --disable-sandbox
fi
FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH=$FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH "$PREBUILT_FLUTTER_TOOL"
