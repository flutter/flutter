    guard let data = fileManager.contents(atPath: exportedEnvPath) else {
      throw XcodeErrorAndExit.error([
        "Unable to run \"flutter assemble\". Failed to read contents of \(exportedEnvPath)"
      ])
    }
    guard let contents = String(data: data, encoding: .utf8) else {
      throw XcodeErrorAndExit.error([
        "Unable to run \"flutter assemble\". Failed to encode contents of \(exportedEnvPath)"
      ])
    }

    var exportedEnv: [String: String] = [:]

    // Remove the "export " prefix and split by newline
    let lines = contents.replacingOccurrences(of: "export ", with: "")
      .components(separatedBy: CharacterSet.newlines)
    for line in lines {
      // Remove the surrounding quotations
      let trimmedLine = line.trimmingCharacters(
        in: CharacterSet(charactersIn: "\"")
      )

      // Get the key and value by splitting by "="
      guard let splitIndex = trimmedLine.firstIndex(of: "=") else {
        continue
      }
      let prevousIndex = trimmedLine.index(before: splitIndex)
      let nextIndex = trimmedLine.index(after: splitIndex)
      let key = String(trimmedLine[...prevousIndex])
      let value = String(trimmedLine[nextIndex...])
      exportedEnv.updateValue(value, forKey: key)
    }
    return exportedEnv
  }

