import Foundation
import Testing

@testable import FlutterToolHelper

@Test(
  "Parse Flutter Build Mode from Environment",
  arguments: [
    (["CONFIGURATION": "Debug"], "Debug"),
    (["CONFIGURATION": "debug"], "Debug"),
    (["CONFIGURATION": "Release"], "Release"),
    (["CONFIGURATION": "release"], "Release"),
    (["CONFIGURATION": "Profile"], "Profile"),
    (["CONFIGURATION": "profile"], "Profile"),
    (["CONFIGURATION": "Debug-vanilla"], "Debug"),
    (["FLUTTER_BUILD_MODE": "Debug-vanilla"], "Debug"),
  ]
)
func parseFlutterBuildModeSuccess(
  env: [String: String],
  expectedBuildMode: String
) async throws {
  let buildMode = try FlutterToolHelper.parseFlutterBuildMode(env: env)
  #expect(buildMode == expectedBuildMode)
}

@Test(
  "Parse Flutter Build Mode from Environment Throws",
  arguments: [
    (["CONFIGURATION": "ASDF"]),
    (["FLUTTER_BUILD_MODE": "ASDF"]),
    ([:]),
  ]
)
func parseFlutterBuildModeThrows(env: [String: String]) async throws {
  #expect(throws: XcodeErrorAndExit.self) {
    try FlutterToolHelper.parseFlutterBuildMode(env: env)
  }
}

