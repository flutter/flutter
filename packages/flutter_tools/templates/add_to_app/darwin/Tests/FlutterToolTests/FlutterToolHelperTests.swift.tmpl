@Test
func updateSymlinkNoChange() async throws {
  let fileManager = MockFileManager()

  let targetBuildMode = "Release"
  try FlutterToolHelper.updateSymlink(
    targetBuildMode: targetBuildMode,
    integrationPackagePath: "/path/to/SwiftPackages/FlutterNativeIntegration",
    fileManager: fileManager
  )

  #expect(fileManager.filesRemoved.count == 0)
  #expect(fileManager.symlinksCreated.count == 0)
}

@Test
func updateSymlinkSuccess() async throws {
  let fileManager = MockFileManager()

  let targetBuildMode = "Debug"
  let targetName = "FlutterPluginRegistrant"
  let expectedLink = "./\(targetBuildMode)"
  let flutterPluginRegistrantPath = "/path/to/SwiftPackages/FlutterNativeIntegration"
  let currentLinkPath = "\(flutterPluginRegistrantPath)/\(targetName)"
  let newTargetPath = "\(flutterPluginRegistrantPath)/\(expectedLink)"
  fileManager.filesExist[newTargetPath] = true
  fileManager.filesExist[currentLinkPath] = true

  try FlutterToolHelper.updateSymlink(
    targetBuildMode: targetBuildMode,
    integrationPackagePath: flutterPluginRegistrantPath,
    fileManager: fileManager
  )

  #expect(fileManager.filesRemoved.count == 1)
  #expect(fileManager.filesRemoved.first == currentLinkPath)
  #expect(fileManager.symlinksCreated.count == 1)
  #expect(fileManager.symlinksCreated[currentLinkPath] == expectedLink)
}

@Test
func updateSymlinkThrowsIfNewLinkDoesNotExist() async throws {
  let fileManager = MockFileManager()
  let targetBuildMode = "Debug"
  let targetName = "FlutterPluginRegistrant"
  let flutterPluginRegistrantPath = "/path/to/SwiftPackages/FlutterPluginRegistrant"
  let currentLinkPath = "\(flutterPluginRegistrantPath)/\(targetName)"
  fileManager.filesExist[currentLinkPath] = true

  #expect(throws: XcodeErrorAndExit.self) {
    try FlutterToolHelper.updateSymlink(
      targetBuildMode: targetBuildMode,
      integrationPackagePath: "/path/to/SwiftPackages/FlutterNativeIntegration",
      fileManager: fileManager
    )
  }
}
