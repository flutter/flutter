import Foundation
import Testing

@testable import FlutterToolHelper

@Test(
  "Copy Flutter.framework for iOS",
  arguments: [
    ("iphonesimulator", "ios-arm64_x86_64-simulator"),
    ("iphoneos", "ios-arm64"),
  ]
)
func copyFlutterFrameworkForIOS(
  platformName: String,
  expectedArch: String
) async throws {
  let fileManager = MockFileManager()
  let processManager = MockFlutterProcessManager()

  let targetBuildMode = "Debug"
  let flutterPluginRegistrantPath = "/path/to/SwiftPackages/FlutterNativeIntegration"
  let xcframework =
    "\(flutterPluginRegistrantPath)/\(targetBuildMode)/Frameworks/Flutter.xcframework"
  let buildDir = "/Build/Products/Debug-\(platformName)"

  fileManager.filesExist[xcframework] = true
  fileManager.filesInDirectory[xcframework] = [
    URL(fileURLWithPath: "\(xcframework)/ios-arm64"),
    URL(fileURLWithPath: "\(xcframework)/ios-arm64_x86_64-simulator"),
  ]
  processManager.expectedURL = "/usr/bin/rsync"
  processManager.expectedArguments = [
    "-av", "--delete", "--filter", "- .DS_Store/",
    "--chmod=Du=rwx,Dgo=rx,Fu=rw,Fgo=r",
    "\(xcframework)/\(expectedArch)/Flutter.framework", buildDir,
  ]
  try FlutterPrebuildToolHelper.copyFlutterFramework(
    targetBuildMode: targetBuildMode,
    env: [
      "FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH": flutterPluginRegistrantPath,
      "PLATFORM_NAME": platformName, "SDKROOT": "\(platformName)26.2",
      "BUILT_PRODUCTS_DIR": buildDir,
    ],
    fileManager: fileManager,
    processManager: processManager
  )
}

