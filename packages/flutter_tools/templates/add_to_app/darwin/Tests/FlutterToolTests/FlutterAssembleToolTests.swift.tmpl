@Test
func runInSandboxSuccessWhenBuildModeCorrect() async throws {
  let fileManager = MockFileManager()
  let processManager = MockFlutterProcessManager()
  let targetBuildMode = "Debug"
  let targetPlatform = FlutterPlatform.ios
  let buildDir = "/Build/Products/\(targetBuildMode)-iphoneos"
  let frameworksDir = "MyApp.app/Frameworks"
  let flutterPackagePath = "/path/to/SwiftPackages/FlutterNativeIntegration"

  let plistContent = plistContentFor(buildMode: "Debug")
  fileManager.fileContents["\(buildDir)/Flutter.framework/Info.plist"] = [
    Data(
      plistContent.utf8
    )
  ]
  fileManager.fileContents[
    "\(buildDir)/\(frameworksDir)/Flutter.framework/Info.plist"
  ] =
    [
      Data(plistContent.utf8)
    ]

  try FlutterAssembleToolHelper.run(
    targetBuildMode: targetBuildMode,
    targetPlatform: targetPlatform,
    env: [
      "SDKROOT": "iphoneos26.2",
      "BUILT_PRODUCTS_DIR": buildDir,
      "TARGET_BUILD_DIR": buildDir,
      "FRAMEWORKS_FOLDER_PATH": frameworksDir,
      "ENABLE_USER_SCRIPT_SANDBOXING": "YES",
      "FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH": flutterPackagePath,
    ],
    fileManager: fileManager,
    processManager: processManager
  )
}

@Test(
  "Calling flutter assemble",
  arguments: [
    (
      FlutterPlatform.ios, "/path/to/flutter_app", "/path/to/flutter_app",
      "ios/Flutter/ephemeral/flutter_native_integration.env"
    ),
    (
      FlutterPlatform.ios, "../flutter_app",
      "/path/to/native_app/../flutter_app",
      "ios/Flutter/ephemeral/flutter_native_integration.env"
    ),
    (
      FlutterPlatform.ios, "/path/to/flutter_app", "/path/to/flutter_app",
      ".ios/Flutter/ephemeral/flutter_native_integration.env"
    ),
    (
      FlutterPlatform.macos, "/path/to/flutter_app", "/path/to/flutter_app",
      "macos/Flutter/ephemeral/flutter_native_integration.env"
    ),
  ]
)
func runWithAssemble(
  targetPlatform: FlutterPlatform,
  flutterAppPath: String,
  resolvedAppPath: String,
  exportEnvPath: String,
) async throws {
  let fileManager = MockFileManager()
  let processManager = MockFlutterProcessManager()
  let targetBuildMode = "Debug"
  let currentBuildMode = "Release"
  let buildDir = "/Build/Products/\(targetBuildMode)-iphoneos"
  let frameworksDir = "MyApp.app/Frameworks"
  let flutterPackagePath = "/path/to/SwiftPackages/FlutterNativeIntegration"
  let xcodeAppPath = "/path/to/native_app"
  let flutterRoot = "/path/to/flutter"
  fileManager.filesExist["\(flutterPackagePath)/./\(targetBuildMode)"] = true
  fileManager.filesExist[resolvedAppPath] = true
  fileManager.filesExist[flutterRoot] = true
  let plistContent = plistContentFor(buildMode: currentBuildMode)
  fileManager.fileContents["\(buildDir)/Flutter.framework/Info.plist"] = [
    Data(
      plistContent.utf8
    )
  ]
  fileManager.fileContents[
    "\(buildDir)/\(frameworksDir)/Flutter.framework/Info.plist"
  ] =
    [
      Data(plistContent.utf8)
    ]

  let exportedEnv = """
    FLUTTER_ROOT=\(flutterRoot)
    FLUTTER_APPLICATION_PATH=\(flutterAppPath)
    FLUTTER_TARGET=lib/main.dart
    """
  let appExportedEnvPath =
    "\(resolvedAppPath)/\(exportEnvPath)"
  fileManager.filesExist[appExportedEnvPath] = true
  fileManager.fileContents[appExportedEnvPath] = [Data(exportedEnv.utf8)]
  processManager.expectedProcesses.append(
    MockProcess(
      expectedURL: "\(flutterRoot)/bin/dart",
      expectedArguments: [
        "\(flutterRoot)/packages/flutter_tools/bin/xcode_backend.dart",
        "build-add-to-app", targetPlatform.rawValue,
      ]
    )
  )
  try FlutterAssembleToolHelper.run(
    targetBuildMode: targetBuildMode,
    targetPlatform: targetPlatform,
    env: [
      "SDKROOT": "iphoneos26.2",
      "BUILT_PRODUCTS_DIR": buildDir,
      "TARGET_BUILD_DIR": buildDir,
      "FRAMEWORKS_FOLDER_PATH": frameworksDir,
      "ENABLE_USER_SCRIPT_SANDBOXING": "NO",
      "FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH": flutterPackagePath,
      "FLUTTER_APPLICATION_PATH": flutterAppPath, "SRCROOT": xcodeAppPath,
    ],
    fileManager: fileManager,
    processManager: processManager
  )
  #expect(fileManager.symlinksCreated.count == 1)
  #expect(
    fileManager.symlinksCreated["\(flutterPackagePath)/FlutterPluginRegistrant"]
      == "./\(targetBuildMode)"
  )
}

@Test func runVerifyBuildModeAndUpdateIfNeeded() async throws {
  let fileManager = MockFileManager()
  let processManager = MockFlutterProcessManager()
  let targetBuildMode = "Debug"
  let currentBuildMode = "Release"
  let targetPlatform = FlutterPlatform.ios
  let buildDir = "/Build/Products/\(targetBuildMode)-iphoneos"
  let frameworksDir = "MyApp.app/Frameworks"
  let flutterPackagePath = "/path/to/SwiftPackages/FlutterNativeIntegration"
  let flutterXCFrameworkPath =
    "\(flutterPackagePath)/\(targetBuildMode)/Frameworks/Flutter.xcframework"

  let appXCFrameworkPath =
    "\(flutterPackagePath)/\(targetBuildMode)/Frameworks/App.xcframework"
  fileManager.filesExist[appXCFrameworkPath] = true
  fileManager.filesInDirectory[appXCFrameworkPath] = [
    URL(fileURLWithPath: "\(appXCFrameworkPath)/ios-arm64"),
    URL(fileURLWithPath: "\(appXCFrameworkPath)/ios-arm64_x86_64-simulator"),
  ]

  fileManager.filesExist["\(flutterPackagePath)/./\(targetBuildMode)"] = true
  fileManager.filesExist[flutterXCFrameworkPath] = true
  fileManager.filesInDirectory[flutterXCFrameworkPath] = [
    URL(fileURLWithPath: "\(flutterXCFrameworkPath)/ios-arm64"),
    URL(
      fileURLWithPath: "\(flutterXCFrameworkPath)/ios-arm64_x86_64-simulator"
    ),
  ]
  fileManager.filesExist[
    "\(flutterPackagePath)/\(targetBuildMode)/Frameworks/App.xcframework"
  ] = true

  fileManager.fileContents["\(buildDir)/Flutter.framework/Info.plist"] = [
    Data(
      plistContentFor(buildMode: currentBuildMode).utf8
    ),
    Data(
      plistContentFor(buildMode: targetBuildMode).utf8
    ),
  ]
  fileManager.fileContents[
    "\(buildDir)/\(frameworksDir)/Flutter.framework/Info.plist"
  ] =
    [
      Data(
        plistContentFor(buildMode: targetBuildMode).utf8
      )
    ]
  processManager.expectedProcesses.append(
    MockProcess(
      expectedURL: "/usr/bin/rsync",
      expectedArguments: [
        "-av", "--delete", "--filter", "- .DS_Store/",
        "--chmod=Du=rwx,Dgo=rx,Fu=rw,Fgo=r",
        "\(flutterXCFrameworkPath)/ios-arm64/Flutter.framework",
        "\(buildDir)/\(frameworksDir)",
      ]
    )
  )
  processManager.expectedProcesses.append(
    MockProcess(
      expectedURL: "/usr/bin/rsync",
      expectedArguments: [
        "-av", "--delete", "--filter", "- .DS_Store/",
        "--chmod=Du=rwx,Dgo=rx,Fu=rw,Fgo=r",
        "\(appXCFrameworkPath)/ios-arm64/App.framework",
        "\(buildDir)/\(frameworksDir)",
      ]
    )
  )
  try FlutterAssembleToolHelper.run(
    targetBuildMode: targetBuildMode,
    targetPlatform: targetPlatform,
    env: [
      "SDKROOT": "iphoneos26.2",
      "BUILT_PRODUCTS_DIR": buildDir,
      "TARGET_BUILD_DIR": buildDir,
      "FRAMEWORKS_FOLDER_PATH": frameworksDir,
      "ENABLE_USER_SCRIPT_SANDBOXING": "NO",
      "FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH": flutterPackagePath,
    ],
    fileManager: fileManager,
    processManager: processManager
  )
  #expect(fileManager.symlinksCreated.count == 1)
  #expect(
    fileManager.symlinksCreated["\(flutterPackagePath)/FlutterPluginRegistrant"]
      == "./\(targetBuildMode)"
  )
}

