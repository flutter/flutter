@Test(
  "Find platform framework inside XCFramework",
  arguments: [
    (
      FlutterPlatform.ios, "Flutter", "iphoneos26.2",
      [
        "/Flutter.xcframework/ios-arm64",
        "/Flutter.xcframework/ios-arm64_x86_64-simulator",
      ], "/Flutter.xcframework/ios-arm64/Flutter.framework"
    ),
    (
      FlutterPlatform.ios, "Flutter", "iphonesimulator26.2",
      [
        "/Flutter.xcframework/ios-arm64",
        "/Flutter.xcframework/ios-arm64_x86_64-simulator",
      ], "/Flutter.xcframework/ios-arm64_x86_64-simulator/Flutter.framework"
    ),
    (
      FlutterPlatform.macos, "FlutterMacOS", "macosx",
      ["/FlutterMacOS.xcframework/macos-arm64_x86_64"],
      "/FlutterMacOS.xcframework/macos-arm64_x86_64/FlutterMacOS.framework"
    ),
  ]
)
func findPlatformFramework(
  targetPlatform: FlutterPlatform,
  frameworkName: String,
  sdkRoot: String,
  platforms: [String],
  expectedFramework: String,
) async throws {
  let fileManager = MockFileManager()
  let xcframeworkURL = URL(fileURLWithPath: "/\(frameworkName).xcframework")
  fileManager.filesInDirectory[xcframeworkURL.path] = platforms.compactMap {
    URL(string: $0)
  }
  let frameworkURL = try FlutterAssembleToolHelper.findPlatformFramework(
    frameworkName: frameworkName,
    xcframeworkURL: xcframeworkURL,
    targetPlatform: targetPlatform,
    env: ["SDKROOT": sdkRoot],
    fileManager: fileManager
  )
  #expect(frameworkURL.path == expectedFramework)
}

func plistContentFor(buildMode: String) -> String {
  return """
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
      <key>BuildMode</key>
      <string>\(buildMode)</string>
    </dict>
    </plist>
    """
}
