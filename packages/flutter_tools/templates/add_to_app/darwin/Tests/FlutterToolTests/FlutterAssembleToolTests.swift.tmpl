@Test
func assembleUsesMergedEnv() async throws {
  let fileManager = MockFileManager()
  let processManager = MockFlutterProcessManager()
  let xcodeAppPath = "/path/to/native_app"
  let flutterRootFromFlutterEnv = "/path/to/flutter"
  let flutterRootFromXcodeEnv = "/path/to/some/other/flutter"
  let flutterAppPath = "/path/to/flutter_app"
  let targetPlatform = FlutterPlatform.ios
  fileManager.filesExist[flutterAppPath] = true
  fileManager.filesExist[flutterRootFromXcodeEnv] = true
  let exportedEnvPath =
    "\(flutterAppPath)/\(targetPlatform)/Flutter/ephemeral/flutter_native_integration.env"
  let exportedEnv = """
    FLUTTER_ROOT=\(flutterRootFromFlutterEnv)
    FLUTTER_APPLICATION_PATH=\(flutterAppPath)
    FLUTTER_TARGET=lib/main.dart
    FLUTTER_BUILD_DIR=build
    FLUTTER_BUILD_NAME=1.0.0
    FLUTTER_BUILD_NUMBER=1
    DART_OBFUSCATION=false
    TRACK_WIDGET_CREATION=true
    TREE_SHAKE_ICONS=false
    PACKAGE_CONFIG=.dart_tool/package_config.json
    """
  fileManager.fileContents[exportedEnvPath] = [Data(exportedEnv.utf8)]
  fileManager.filesExist[exportedEnvPath] = true
  processManager.expectedProcesses.append(
    MockProcess(
      expectedURL: "\(flutterRootFromXcodeEnv)/bin/dart",
      expectedArguments: [
        "\(flutterRootFromXcodeEnv)/packages/flutter_tools/bin/xcode_backend.dart",
        "build-add-to-app", targetPlatform.rawValue,
      ],
      expectedEnv: [
        "FLUTTER_APPLICATION_PATH": flutterAppPath,
        "SRCROOT": xcodeAppPath,
        "FLUTTER_ROOT": flutterRootFromXcodeEnv,
        "FLUTTER_TARGET": "lib/main.dart",
        "FLUTTER_BUILD_DIR": "build",
        "FLUTTER_BUILD_NAME": "1.0.0",
        "FLUTTER_BUILD_NUMBER": "1",
        "DART_OBFUSCATION": "false",
        "TRACK_WIDGET_CREATION": "true",
        "TREE_SHAKE_ICONS": "false",
        "PACKAGE_CONFIG": ".dart_tool/package_config.json",
      ]
    )
  )
  processManager.validateEnvironment = true
  try FlutterAssembleToolHelper.assemble(
    appPath: flutterAppPath,
    targetPlatform: targetPlatform,
    env: [
      "FLUTTER_APPLICATION_PATH": flutterAppPath, "SRCROOT": xcodeAppPath,
      "FLUTTER_ROOT": flutterRootFromXcodeEnv,
    ],
    fileManager: fileManager,
    processManager: processManager
  )
}

@Test(
  "Copy Flutter.framework for iOS",
  arguments: [
    ("iphonesimulator", "ios-arm64_x86_64-simulator"),
    ("iphoneos", "ios-arm64"),
  ]
)
func copyAndCodesignFrameworkForIOS(
  platformName: String,
  expectedArch: String
) async throws {
  let fileManager = MockFileManager()
  let processManager = MockFlutterProcessManager()

  let targetBuildMode = "Debug"
  let flutterPackagePath = "/path/to/SwiftPackages/FlutterNativeIntegration"
  let xcframework =
    "\(flutterPackagePath)/\(targetBuildMode)/Frameworks/Flutter.xcframework"
  let buildDir = "/Build/Products/Debug-\(platformName)"
  let frameworksDir = "MyApp.app/Frameworks"

  fileManager.filesExist[xcframework] = true
  fileManager.filesInDirectory[xcframework] = [
    URL(fileURLWithPath: "\(xcframework)/ios-arm64"),
    URL(fileURLWithPath: "\(xcframework)/ios-arm64_x86_64-simulator"),
  ]
  processManager.expectedProcesses.append(
    contentsOf: [
      MockProcess(
        expectedURL: "/usr/bin/rsync",
        expectedArguments: [
          "-av", "--delete", "--filter", "- .DS_Store/",
          "--chmod=Du=rwx,Dgo=rx,Fu=rw,Fgo=r",
          "\(xcframework)/\(expectedArch)/Flutter.framework",
          "\(buildDir)/\(frameworksDir)",
        ]
      ),
      MockProcess(
        expectedURL: "/usr/bin/codesign",
        expectedArguments: [
          "--force", "--verbose", "--sign", "-", "--",
          "\(buildDir)/\(frameworksDir)/Flutter.framework/Flutter",
        ]
      ),
    ]
  )
  try FlutterAssembleToolHelper.copyAndCodesignFramework(
    frameworkName: "Flutter",
    packagePath: flutterPackagePath,
    targetBuildMode: targetBuildMode,
    targetPlatform: FlutterPlatform.ios,
    env: [
      "FLUTTER_NATIVE_INTEGRATION_PACKAGE_PATH": flutterPackagePath,
      "PLATFORM_NAME": platformName, "SDKROOT": "\(platformName)26.2",
      "BUILT_PRODUCTS_DIR": buildDir, "TARGET_BUILD_DIR": buildDir,
      "FRAMEWORKS_FOLDER_PATH": frameworksDir,
      "EXPANDED_CODE_SIGN_IDENTITY": "-",
    ],
    fileManager: fileManager,
    processManager: processManager
  )
}

