@Test(
  "Calling flutter assemble",
  arguments: [
    (FlutterPlatform.ios, "/path/to/flutter_app", "/path/to/flutter_app"),
    (FlutterPlatform.ios, "../flutter_app", "/path/to/native_app/../flutter_app"),
    (FlutterPlatform.macos, "/path/to/flutter_app", "/path/to/flutter_app"),
  ]
)
func assemble(
  targetPlatform: FlutterPlatform,
  flutterAppPath: String,
  resolvedAppPath: String
) async throws {
  let fileManager = MockFileManager()
  let processManager = MockFlutterProcessManager()
  let xcodeAppPath = "/path/to/native_app"
  let flutterRoot = "/path/to/flutter"
  fileManager.filesExist[resolvedAppPath] = true
  fileManager.filesExist[flutterRoot] = true
  let exportedEnv = """
    #!/bin/sh
    # This is a generated file; do not edit or check into version control.
    export "FLUTTER_ROOT=\(flutterRoot)"
    export "FLUTTER_APPLICATION_PATH=\(flutterAppPath)"
    export "FLUTTER_TARGET=lib/main.dart"
    export "FLUTTER_BUILD_DIR=build"
    export "FLUTTER_BUILD_NAME=1.0.0"
    export "FLUTTER_BUILD_NUMBER=1"
    export "DART_OBFUSCATION=false"
    export "TRACK_WIDGET_CREATION=true"
    export "TREE_SHAKE_ICONS=false"
    export "PACKAGE_CONFIG=.dart_tool/package_config.json"
    """
  fileManager.fileContents["\(resolvedAppPath)/\(targetPlatform)/Flutter/flutter_export_environment.sh"] =
    Data(exportedEnv.utf8)
  processManager.expectedURL = "\(flutterRoot)/bin/dart"
  processManager.expectedArguments = [
    "\(flutterRoot)/packages/flutter_tools/bin/xcode_backend.dart",
    "build-native", targetPlatform.rawValue,
  ]
  try FlutterAssembleToolHelper.assemble(
    command: "build-native",
    targetPlatform: targetPlatform,
    env: ["FLUTTER_APPLICATION_PATH": flutterAppPath, "SRCROOT": xcodeAppPath],
    fileManager: fileManager,
    processManager: processManager
  )
}

