import Foundation
import Testing

@testable import FlutterToolHelper

@Test(
  "Verify build mode in framework Info.plist",
  arguments: [
    (FlutterPlatform.ios, "Flutter.framework/Info.plist", "iphonesimulator", "Debug", "debug"),
    (FlutterPlatform.ios, "Flutter.framework/Info.plist", "iphonesimulator", "Release", "debug"),
    (FlutterPlatform.ios, "Flutter.framework/Info.plist", "iphoneos", "Debug", "debug"),
    (FlutterPlatform.ios, "Flutter.framework/Info.plist", "iphoneos", "Release", "release"),
    (FlutterPlatform.macos, "FlutterMacOS.framework/Resources/Info.plist", "macosx", "Debug", "debug"),
    (FlutterPlatform.macos, "FlutterMacOS.framework/Resources/Info.plist", "macosx", "Release", "release"),
  ]
)
func verifyFlutterFrameworkSuccess(
  targetPlatform: FlutterPlatform,
  infoPlistPath: String,
  sdk: String,
  targetBuildMode: String,
  expectedBuildMode: String
) async throws {
  let buildDir = "/Build/Products/\(targetBuildMode)-\(sdk)"
  let frameworksDir = "MyApp.app/Frameworks"

  let fileManager = MockFileManager()
  let plistContent = """
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
      <key>BuildMode</key>
      <string>\(expectedBuildMode)</string>
    </dict>
    </plist>
    """
  fileManager.fileContents["\(buildDir)/\(infoPlistPath)"] = Data(plistContent.utf8)
  fileManager.fileContents["\(buildDir)/\(frameworksDir)/\(infoPlistPath)"] = Data(plistContent.utf8)

  try FlutterAssembleToolHelper.verifyFlutterFramework(
    targetBuildMode: targetBuildMode,
    targetPlatform: targetPlatform,
    env: [
      "SDKROOT": "\(sdk)26.2",
      "BUILT_PRODUCTS_DIR": buildDir,
      "TARGET_BUILD_DIR": buildDir,
      "FRAMEWORKS_FOLDER_PATH": frameworksDir,
    ],
    fileManager: fileManager
  )
}

