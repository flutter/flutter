import Foundation
import Testing

@testable import FlutterPluginTool
@testable import FlutterToolHelper

@Test(
  "Extract command line arguments",
  arguments: [
    (["/", "Debug"], "Invalid arguments: [/, Debug]"),
    (
      [
        "/path/to/SwiftPackages...", "Dummy",
        "/path/to/SwiftPackages/FlutterPluginRegistrant",
      ], "Invalid build mode: Dummy"
    ),
    (
      ["/path/to/SwiftPackages...", "Debug", "/path/to/SwiftPackages/Other"],
      "Invalid package path: /path/to/SwiftPackages/Other"
    ),
  ]
)
func extractArgumentsThrowsError(
  arguments: [String],
  expectedErrorMessage: String
) async throws {
  #expect(throws: XcodeErrorAndExit.error([expectedErrorMessage])) {
    try FlutterPluginTool.extractArguments(arguments: arguments)
  }
}

@Test
func extractArgumentsSuccess() async throws {
  let (buildMode, packagePath) = try FlutterPluginTool.extractArguments(
    arguments: ["", "Debug", "/path/to/SwiftPackages/FlutterPluginRegistrant"]
  )
  #expect(buildMode == "Debug")
  #expect(packagePath == "/path/to/SwiftPackages/FlutterPluginRegistrant")
}

@Test(
  "Find FlutterPluginRegistrant Swift Package",
  arguments: [
    (
      "/path/to/SwiftPackages/FlutterPluginRegistrant",
      "/path/to/SwiftPackages/FlutterPluginRegistrant"
    ),
    (
      "/path/to/SwiftPackages/FlutterConfigurationPlugin",
      "/path/to/SwiftPackages/FlutterPluginRegistrant"
    ),
  ]
)
func findFlutterPluginRegistrant(path: String, expectedResultPath: String) async throws {
  let found = FlutterPluginTool.findFlutterPluginRegistrant(packagePath: path)
  #expect(found.path == expectedResultPath)
}
