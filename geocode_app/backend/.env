# Application Settings
DEBUG=True
LOG_LEVEL=INFO
API_TITLE=Real-Time Hazard Monitoring System
API_VERSION=1.0.0

# Database
DATABASE_URL=sqlite:///./data/hazard_system.db
SQLITE_DB_PATH=./data/hazard_system.db

# Redis
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=alerts@hazard-monitor.com
ALERT_EMAIL_TO=ashwanthashwanth2006@gmail.com

# NASA Data Source Credentials
NASA_EARTHDATA_USERNAME=your_nasa_username
NASA_EARTHDATA_PASSWORD=your_nasa_password

# JAXA Data Source Credentials
JAXA_FTP_USER=your_jaxa_ftp_user
JAXA_FTP_PASSWORD=your_jaxa_ftp_password

# ESA Copernicus Hub Credentials
ESA_COPERNICUS_USER=your_esa_user
ESA_COPERNICUS_PASSWORD=your_esa_password

# IMD Credentials
IMD_FTP_USER=your_imd_ftp_user
IMD_FTP_PASSWORD=your_imd_ftp_password

# Sentry (Error Tracking)
SENTRY_DSN=

# Geographic Configuration (Tamil Nadu)
# Tamil Nadu Bounding Box: South 8.0°N, West 76.7°E, North 13.3°N, East 80.4°E

# Risk Thresholds for Alerts
FLOOD_CRITICAL_THRESHOLD=100
LANDSLIDE_CRITICAL_THRESHOLD=100
DROUGHT_CRITICAL_THRESHOLD=100

# ML Models Path
ML_MODELS_PATH=./models

# Data Retention (days)
DATA_RETENTION_DAYS=30
